resource "random_password" "api_key" {
  length           = 32
  special          = false
  override_special = "_%@"
}

resource "random_password" "admin_user" {
  length           = 8
  special          = false
  override_special = "_%@"
}

// This block will deploy the parallels-desktop
resource "parallels-desktop_deploy" "deploy-intel-mac" {
  api_config {
    port                   = "5682"
    log_level              = "debug"
    mode                   = "api"
    devops_version         = "0.9.12685587401-beta"
    root_password          = "6J9W67-SG4ANH-4V2BEE-6P4EJE-3D7H2X"
    enable_logging         = true
    enable_tls             = false
    tls_private_key        = ""
    tls_certificate        = ""
    tls_port               = 8443
    enable_port_forwarding = true
    environment_variables = {
      "DATABASE_SAVE_INTERVAL_MINUTES" = "3",
      "SYSTEM_RESERVED_CPU" : "2",
      "PARALLELS_DESKTOP_REFRESH_INTERVAL" : "40",
      "CATALOG_CACHE_FOLDER" : "/Users/ec2-user/cache",
    }
  }

  orchestrator_registration {
    tags = [
      "builder",
      "x86_64"
    ]
    description = "London Intel Mac"

    orchestrator {
      schema = "https"
      host   = "devops.local-build.co"
      port   = "443"
      authentication {
        username = "root"
        password = "Nmo5c2U1YTZycWc0Ojc4YmZkOWNlZjJmMjU0Z000"
      }
    }
  }

  ssh_connection {
    user      = var.intel_mac_user
    password  = var.intel_mac_password
    host      = var.intel_mac_host
    host_port = var.intel_mac_port
  }
}
